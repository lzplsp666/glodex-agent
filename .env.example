# ========================================
# Globex Agent — 环境变量配置模板
# 复制为 .env 后填入真实值
# ========================================

# ---------- LLM 配置 ----------
# 供应商 API 地址（默认 DeepSeek，换成百炼/豆包/智谱只需改下面三行）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat

# 生成参数
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ---------- 后续扩展 ----------
