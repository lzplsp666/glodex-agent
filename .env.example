# ========== LLM 配置 ==========
# 主 / 子 AgentLoop 共用同一个 LLM（同质 fork 的核心要求）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=你的大模型_API_KEY
LLM_MAIN=qwen3-30b-a3b-instruct
LLM_JUDGE=qwen-max

# ========== 三塔向量召回 ==========
# Faiss / Milvus 选其一即可
ANN_BACKEND=Milvus
ANN_INDEX_PATH=./data/item_index.faiss
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=products
MILVUS_VECTOR_FIELD=embedding
MILVUS_DB_NAME=
MILVUS_TOKEN=
TOWER_USER_ENDPOINT=http://localhost:8081/encode/user
TOWER_QUERY_ENDPOINT=http://localhost:8081/encode/query
TOWER_ITEM_ENDPOINT=http://localhost:8081/encode/item
TOWER_TIMEOUT_SEC=5.0

# ========== 长期记忆 Store ==========
STORE_BACKEND=redis
STORE_REDIS_URL=redis://localhost:6379/2

# ========== 跨平台商品检索 ==========
ITEM_SEARCH_INDEX_PATH=./data/products.jsonl

# ========== 商品数据采集 ==========
DINGDANXIA_API_KEY=你的_订单侠_API_KEY
DINGDANXIA_BASE_URL=https://api.tbk.dingdanxia.com

# ========== Web 兜底搜索 ==========
BOCHA_API_KEY=你的_BoCha_API_KEY
BOCHA_WEB_SEARCH_ENDPOINT=https://api.bochaai.com/v1/web-search

# ========== 上下文压缩 ==========
COMPRESS_KEEP_RECENT=3
COMPRESS_MAX_TOKENS=12000

# ========== AGUI / WebSocket 通讯 ==========
WS_PING_INTERVAL=20

# ========== 评测训练自动采集 ==========
RUBRIC_HIGH_SCORE=70
TRACE_LOG_DIR=./data/traces
